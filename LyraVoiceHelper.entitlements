<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Движки whisper.cpp/llama.cpp загружают вшитые dylib, подписанные тем же
         самоподписанным сертификатом (TeamIdentifier not set). Library validation
         под hardened runtime иначе отвергает их как «разные Team ID». -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
